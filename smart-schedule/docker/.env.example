# Smart Schedule — Docker environment variables
# Copy to .env and fill in values before running docker compose.
#
# Generate keys:
#   JWT_SECRET:       openssl rand -hex 32
#   SECRET_KEY_BASE:  openssl rand -hex 64
#   POSTGRES_PASSWORD: openssl rand -hex 16
#   ANON_KEY / SERVICE_ROLE_KEY: Generate JWTs signed with JWT_SECRET
#     - ANON_KEY payload:         { "role": "anon", "iss": "supabase", "iat": <now>, "exp": <+10y> }
#     - SERVICE_ROLE_KEY payload: { "role": "service_role", "iss": "supabase", "iat": <now>, "exp": <+10y> }

# ─── Postgres ────────────────────────────────────────────────────
POSTGRES_USER=supabase
POSTGRES_PASSWORD=
POSTGRES_DB=smart_schedule
POSTGRES_PORT=5432

# ─── JWT ─────────────────────────────────────────────────────────
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# ─── Realtime ────────────────────────────────────────────────────
SECRET_KEY_BASE=

# ─── GoTrue (Auth) + Frontend ───────────────────────────────────
# SITE_URL = public-facing origin (used by GoTrue + frontend build)
# API_EXTERNAL_URL = same as SITE_URL for single-domain deployments
API_EXTERNAL_URL=http://localhost
SITE_URL=http://localhost
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
JWT_EXPIRY=3600

# Azure AD — set these for production
AZURE_ENABLED=false
AZURE_CLIENT_ID=
AZURE_SECRET=
# Must match your IdP app redirect URI exactly (GoTrue callback endpoint)
# Local example: http://localhost/auth/v1/callback
AZURE_REDIRECT_URI=http://localhost/auth/v1/callback
AZURE_URL=

# Custom access token hook (Postgres function) for JWT claim enrichment
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_ENABLED=true
# Default local URI invokes public.custom_access_token_hook inside Postgres
GOTRUE_HOOK_CUSTOM_ACCESS_TOKEN_URI=pg-functions://postgres/public/custom_access_token_hook

# ─── Azure AD (Graph API directory search) ─────────────────────
# Used by search_directory_users() Postgres function for user lookup
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ─── AI Agent ────────────────────────────────────────────────────
# Encryption keys for AI credential storage (AES-256-GCM)
# Generate: openssl rand -hex 32
AI_ENCRYPTION_KEY_CURRENT=
# Previous key for seamless rotation (optional, set during key rotation)
AI_ENCRYPTION_KEY_PREVIOUS=
# Enable/disable the scheduled task runner
SCHEDULER_ENABLED=true
# Poll interval in milliseconds for the scheduler
SCHEDULER_POLL_INTERVAL_MS=30000

# ─── Caddy ───────────────────────────────────────────────────────
# Set to your domain for production (enables auto-TLS)
SITE_ADDRESS=localhost
